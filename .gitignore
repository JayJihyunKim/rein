# Claude Code 로컬 설정 (공유 불가)
.claude/settings.local.json

# Claude Code 런타임 lock 파일 (세션별 scheduled-tasks 동시성 제어)
/.claude/scheduled_tasks.lock

# rein runtime state (governance stage, base snapshots, etc).
# rein-dev 메인테이너 repo 에서는 governance.json 을 `git add -f` 로 versioning.
# 사용자 프로젝트 (rein init 후) 는 이 파일을 gitignore 로 유지해
# per-project runtime state 를 commit 에서 배제한다.
# Plan C Task 1.3 — anchored form (repo-root only) + backup dirs + job logs.
/.claude/.rein-state/

# rein operational hygiene (Spec C / Plan C Task 1.3)
.rein-prune-backup-*/
.rein-remove-backup-*/
/.claude/cache/jobs/

# rein hook runtime cache + state machine runtime (영역 A/C, 2026-05-22).
# .rein/project.json 만 ship (branch-strategy 포함 대상). cache/state.json 은
# hook 실행 중 생성되는 휘발성 산출물 — commit 배제.
/.rein/cache/
/.rein/state.json
/.rein/state-pending-*.log

# rein first-session onboarding marker (ONBOARD-1) — 영속 runtime marker, 추적 제외.
/.rein/.onboarded

# rein session-state git snapshot (GS-1) — 훅 생성 git 스냅샷, 매 세션 재생성, commit 배제.
/.rein/state/

# rein incident aggregate lock (휘발성 — 매 세션 hook 이 갱신하는 commit noise)
/trail/incidents/.aggregate.lock

# rein incident 파이프라인 런타임 커서 (휘발성 세션 상태 — 매 세션 갱신되는
# commit noise 라 추적 제외. 파일 자체는 집계 파이프라인의 기능 파일로 유지)
/trail/incidents/.last-processed-line
/trail/incidents/.last-aggregate-state.json
/trail/incidents/.session-start-line

# rein meta-check 텔레메트리 (2026-07-13 retire — 훅이 더 이상 안 씀. 구버전
# 플러그인 캐시가 세션 중 생성하는 잔재 방어용 ignore)
/trail/inbox/*-meta-check.jsonl

# rein 보안-surface 면제 audit log (휘발성 — 면제 커밋마다 게이트가 append 하는
# runtime 기록. 커밋 후 다시 dirty 되는 commit noise 라 추적 제외; 로컬 운영자 가시성용)
/trail/incidents/security-surface-exempt.log

# Git worktrees (로컬 작업 분리용)
.worktrees/
worktrees/

# Serena MCP 로컬 프로젝트 캐시 (도구 상태 — 공유 불가)
.serena/
