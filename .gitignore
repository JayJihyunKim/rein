# Claude Code 로컬 설정 (공유 불가)
.claude/settings.local.json

# rein runtime state (governance stage, base snapshots, etc).
# rein-dev 메인테이너 repo 에서는 governance.json 을 `git add -f` 로 versioning.
# 사용자 프로젝트 (rein init 후) 는 이 파일을 gitignore 로 유지해
# per-project runtime state 를 commit 에서 배제한다.
# Plan C Task 1.3 — anchored form (repo-root only) + backup dirs + job logs.
/.claude/.rein-state/

# rein operational hygiene (Spec C / Plan C Task 1.3)
.rein-prune-backup-*/
.rein-remove-backup-*/
/.claude/cache/jobs/

# Git worktrees (로컬 작업 분리용)
.worktrees/
worktrees/
