{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-bootstrap.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-load-trail.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-rules.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit-rules.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit-trail-bootstrap-gate.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/trail-rotate.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit-dod-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-bootstrap-gate.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-safety-guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(pytest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(jest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(vitest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(mocha *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm run test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(yarn test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(python -m pytest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx jest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx vitest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(bash tests/*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-test-commit-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(pytest)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(pytest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm test)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(yarn test)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(yarn test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm test)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm run test)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm run test *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(cargo build)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(cargo build *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(docker build)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(docker build *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(playwright)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(playwright *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(make)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(make *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(tsc)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(tsc *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(python -m pytest)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(python -m pytest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx jest)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx jest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx vitest)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx vitest *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-rules.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-agent-rules.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-hygiene.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-review-gate.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-index-sync-inbox.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-spec-review-gate.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-plan-coverage.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-dod-routing-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-design-plan-coverage-rule.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-routing-procedure-rule.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-aggregator.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-agent-review-trigger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-session-gate.sh"
          }
        ]
      }
    ]
  }
}
