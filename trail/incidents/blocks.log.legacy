2026-04-13T09:03:32|pre-bash-guard|파이프 쉘 실행|cat > /tmp/trace_cache.sh << 'EOF'
#!/bin/bash
SCRIPT_DIR="/Users/jihyun/Local_Projects/claude-code-ai-native/tests/hooks"
source "$SCRIPT_DIR/lib/test-harness.sh"

make_input() {
  local abs="$SANDBOX/$1"
  printf '{"tool_input":{"file_path":"%s"}}' "$abs"
}

sandbox_setup "pre-edit-dod-gate.sh" || exit 1

seed_dod "dod-2026-04-13-done-task.md" "# done"
seed_inbox "2026-04-13-done-task.md" "# completed"
mkdir -p "$SANDBOX/scripts"
touch "$SANDBOX/scripts/foo.sh"

# Manually calculate the cache key like the hook does
DOD_DIR="$SANDBOX/SOT/dod"
INBOX_DIR="$SANDBOX/SOT/inbox"

CACHE_KEY=$(echo "${SANDBOX}" | md5 -q 2>/dev/null || echo "${SANDBOX}" | md5sum 2>/dev/null | cut -c1-8)
DIR_MTIME=$(
  {
    stat -f %m "$DOD_DIR" 2>/dev/null
    stat -f %m "$INBOX_DIR" 2>/dev/null
    stat -c %Y "$DOD_DIR" 2>/dev/null
    stat -c %Y "$INBOX_DIR" 2>/dev/null
  } | sort -nr | head -1
)
CACHE="/tmp/.claude-dod-${CACHE_KEY}-${DIR_MTIME:-0}"

echo "SANDBOX: $SANDBOX"
echo "CACHE_KEY: $CACHE_KEY"
echo "DIR_MTIME: $DIR_MTIME"
echo "CACHE: $CACHE"
echo "Cache file exists: $([ -f "$CACHE" ] && echo YES || echo NO)"

# Now run the hook
INPUT=$(make_input scripts/foo.sh)
printf '%s' "$INPUT" | bash "$SANDBOX/.claude/hooks/pre-edit-dod-gate.sh"
HOOK_EXIT=$?

echo "Hook exit: $HOOK_EXIT"

sandbox_teardown
EOF
bash /tmp/trace_cache.sh
